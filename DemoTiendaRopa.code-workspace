{
  "folders": [
    {
      "name": "🎨 FRONTEND (React)",
      "path": "client",
    },
    {
      "name": "⚙️ BACKEND (Express)",
      "path": "server",
    },
    {
      "name": "📁 RAÍZ DEL PROYECTO",
      "path": ".",
    },
  ],
  "settings": {
    // --- FORMATO Y CALIDAD DE CÓDIGO ---
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
    },

    // --- MANEJO DE ARCHIVOS E IGNORADOS ---
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true,
      "**/node_modules": false, // Mantenlo visible si necesitas revisar paquetes
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/build": true,
      "**/.next": true,
      "**/coverage": true,
    },

    // --- TERMINAL INTEGRADA ---
    // Configura rutas relativas para abrir terminales rápido
    "terminal.integrated.cwd": "${workspaceFolder}",

    // --- AJUSTES DE EDITOR ---
    "editor.tabSize": 2,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    // --- CONFIGURACIÓN DE LENGUAJES ---
    "[javascript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[javascriptreact]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[json]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[jsonc]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "conventionalCommits.scopes": ["footer"],
  },

  // --- EXTENSIONES RECOMENDADAS PARA EL EQUIPO/WORKSPACE ---
  "extensions": {
    "recommendations": [
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss", // Imprescindible si usas Tailwind en React
      "dsznajder.es7-react-js-snippets",
      "eamodio.gitlens",
      "humao.rest-client", // Excelente para probar tus endpoints de Express sin abrir Postman
    ],
  },
}
